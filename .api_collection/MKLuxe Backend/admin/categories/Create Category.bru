meta {
  name: Create Category
  type: http
  seq: 1
}

post {
  url: {{BACKEND_URI}}/api/v1/admin/categories
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "BGS",
    "description": "Gold and Diamond rings",
    "sort_order": 1
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
