meta {
  name: Submit Inquiry
  type: http
  seq: 1
}

post {
  url: {{BACKEND_URI}}/api/v1/inquiries
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "product_id": "PASTE_PRODUCT_ID_HERE",
    "customer_name": "Jane Doe",
    "phone": "+19876543210",
    "message": "I am interested in buying this ring."
  }
  
}

settings {
  encodeUrl: true
}
